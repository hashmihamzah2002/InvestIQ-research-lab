# InvestIQ Research Lab — environment template
# Copy to .env — the app is FULLY FUNCTIONAL with this file unchanged
# (deterministic mock data + CSV imports). Add free keys to light up real data.

# ----------------------------------------------------------------------------
# Database (SQLite by default; see docs/DEPLOYMENT.md for PostgreSQL)
# ----------------------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# ----------------------------------------------------------------------------
# Provider credentials — ALL OPTIONAL. Missing key = adapter is skipped in its
# chain. Never commit real values; this file documents shape only.
# ----------------------------------------------------------------------------

# SEC EDGAR needs NO key — only a descriptive User-Agent with contact email
# (SEC fair-access policy). Setting this enables REAL filings + XBRL
# fundamentals immediately, for free.
# SEC_EDGAR_USER_AGENT="InvestIQ Research Lab you@example.com"

# FRED (macro: rates, CPI, unemployment, GDP, yields) — free key:
# https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=""

# Alpha Vantage (prices, fundamentals) — free key (25 requests/day):
# https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=""

# Finnhub (prices, company news with sentiment) — free key (60 calls/min):
# https://finnhub.io/register
# FINNHUB_API_KEY=""

# Financial Modeling Prep (statements, ratios) — free tier:
# https://site.financialmodelingprep.com/developer/docs
# FMP_API_KEY=""

# ----------------------------------------------------------------------------
# Provider fallback chains — comma-separated adapter names tried in order.
# Unconfigured adapters are skipped. Keep "mock" last: it never fails, so the
# daily refresh always completes. Available names per category:
#   market-data:  finnhub, alpha-vantage, csv, mock
#   fundamentals: fmp, alpha-vantage, sec-edgar, csv, mock
#   filings:      sec-edgar, csv, mock
#   news:         finnhub, csv, mock
#   macro:        fred, csv, mock
# ----------------------------------------------------------------------------
# MARKET_DATA_PROVIDERS="finnhub,alpha-vantage,csv,mock"
# FUNDAMENTALS_PROVIDERS="fmp,alpha-vantage,csv,mock"
# FILINGS_PROVIDERS="sec-edgar,csv,mock"
# NEWS_PROVIDERS="finnhub,csv,mock"
# MACRO_PROVIDERS="fred,csv,mock"

# ----------------------------------------------------------------------------
# Tuning
# ----------------------------------------------------------------------------
# HTTP_TIMEOUT_MS=15000        # per external request
# API_CACHE_ENABLED=1          # 0 disables the response cache (debugging)
# LOG_LEVEL=info               # debug | info | warn | error
# LOG_FORMAT=pretty            # pretty | json (default: pretty in dev)
# LIVE_SMOKE=                  # set to 1 to run network smoke tests
